;; ============================================================
;; 通用工具库 - 可复用的高阶函数和数据处理工具集
;;
;; ```mermaid
;; graph LR
;;     subgraph 谓词判断
;;         A1[任一满足?] --- A2[全部满足?]
;;     end
;;     subgraph 查找与过滤
;;         B1[查找] --- B2[分组] --- B3[计数]
;;     end
;;     subgraph 变换
;;         C1[去重通用] --- C2[展平] --- C3[索引映射]
;;     end
;; ```
;;
;; 设计原则:
;;   - 所有函数均为纯函数，无副作用
;;   - 基于归约(reduce)模式实现复杂操作
;;   - 字典作为累加器实现 O(1) 查找
;;
;; 导出函数:
;;   任一满足?  (谓词, 列表) → 布尔值
;;   全部满足?  (谓词, 列表) → 布尔值
;;   查找       (谓词, 列表) → 元素 或 #f
;;   去重通用   (取键函数, 列表) → 去重后列表
;;   分组       (谓词, 列表) → {"是": [...], "否": [...]}
;;   计数       (谓词, 列表) → 数字
;;   展平       (嵌套列表) → 扁平列表
;;   索引映射   (函数, 列表) → 带索引的映射结果
;; ============================================================


;; ------------------------------------------------------------
;; 任一满足?
;; 判断列表中是否存在至少一个元素使谓词返回真
;; 等价于: Python 的 any(pred(x) for x in lst)
;; 参数: 谓词 - 接受一个参数返回布尔值的函数; 列表
;; 返回: #t 或 #f
;; ------------------------------------------------------------

【定义 【任一满足? 谓词 列表】
  【归约
    【道 【结果 项】 【或 结果 【谓词 项】】】
    #f
    列表】】


;; ------------------------------------------------------------
;; 全部满足?
;; 判断列表中是否所有元素都使谓词返回真
;; 等价于: Python 的 all(pred(x) for x in lst)
;; 参数: 谓词 - 接受一个参数返回布尔值的函数; 列表
;; 返回: #t 或 #f
;; ------------------------------------------------------------

【定义 【全部满足? 谓词 列表】
  【归约
    【道 【结果 项】 【与 结果 【谓词 项】】】
    #t
    列表】】


;; ------------------------------------------------------------
;; 查找
;; 返回列表中第一个使谓词为真的元素
;; 使用归约 + "已找到" 标志位实现提前锁定（找到后不再更新）
;; 参数: 谓词; 列表
;; 返回: 找到的元素，或 #f（未找到）
;; ------------------------------------------------------------

【定义 【查找 谓词 列表】
  【取值
    【归约
      【道 【累加器 项】
        【如果 【取值 累加器 "已找到"】
          累加器
          【如果 【谓词 项】
            【字典 "已找到" #t "值" 项】
            累加器】】】
      【字典 "已找到" #f "值" #f】
      列表】
    "值"】】


;; ------------------------------------------------------------
;; 去重通用
;; 按自定义 key 函数去重，保留每个 key 首次出现的元素
;; 内部使用字典做 O(1) 已见判断（比列表线性搜索快得多）
;; 参数: 取键函数 - 从元素提取唯一键; 列表
;; 返回: 去重后的列表
;; ------------------------------------------------------------

【定义 【去重通用 取键函数 列表】
  【取值
    【归约
      【道 【累加器 项】
        【令 【【已见 【取值 累加器 "已见"】】
              【结果 【取值 累加器 "结果"】】
              【键 【取键函数 项】】】
          【如果 【取值 已见 键】
            累加器
            【字典 "已见" 【赋值 已见 键 #t】
                   "结果" 【追加 结果 【序列 项】】】】】】
      【字典 "已见" 【字典】 "结果" 【序列】】
      列表】
    "结果"】】


;; ------------------------------------------------------------
;; 分组
;; 按谓词将列表一次遍历分为两组
;; 比两次 filter 效率更高（只遍历一次）
;; 参数: 谓词; 列表
;; 返回: {"是": [满足谓词的元素], "否": [不满足的元素]}
;; ------------------------------------------------------------

【定义 【分组 谓词 列表】
  【归约
    【道 【累加器 项】
      【如果 【谓词 项】
        【字典 "是" 【追加 【取值 累加器 "是"】 【序列 项】】
               "否" 【取值 累加器 "否"】】
        【字典 "是" 【取值 累加器 "是"】
               "否" 【追加 【取值 累加器 "否"】 【序列 项】】】】】
    【字典 "是" 【序列】 "否" 【序列】】
    列表】】


;; ------------------------------------------------------------
;; 计数
;; 统计列表中满足谓词的元素数量
;; 参数: 谓词; 列表
;; 返回: 满足条件的元素个数（整数）
;; ------------------------------------------------------------

【定义 【计数 谓词 列表】
  【归约
    【道 【n 项】 【如果 【谓词 项】 【+ n 1】 n】】
    0
    列表】】


;; ------------------------------------------------------------
;; 展平
;; 将嵌套列表展平一层: [[1,2],[3,4]] → [1,2,3,4]
;; 非列表元素会被包裹为单元素列表后追加
;; 参数: 列表（可能包含子列表）
;; 返回: 展平后的一维列表
;; ------------------------------------------------------------

【定义 【展平 列表】
  【归约
    【道 【累加器 项】
      【如果 【是列表? 项】
        【追加 累加器 项】
        【追加 累加器 【序列 项】】】】
    【序列】
    列表】】


;; ------------------------------------------------------------
;; 索引映射
;; 类似 map 但额外传入从 0 开始的索引作为第一个参数
;; 函数签名: (索引, 元素) → 新元素
;; 内部用归约累加器跟踪当前索引
;; 参数: 函数 - (idx, item) → result; 列表
;; 返回: 映射结果列表
;; ------------------------------------------------------------

【定义 【索引映射 函数 列表】
  【取值
    【归约
      【道 【累加器 项】
        【令 【【索引 【取值 累加器 "索引"】】
              【结果 【取值 累加器 "结果"】】】
          【字典 "索引" 【+ 索引 1】
                 "结果" 【追加 结果 【序列 【函数 索引 项】】】】】】
      【字典 "索引" 0 "结果" 【序列】】
      列表】
    "结果"】】
