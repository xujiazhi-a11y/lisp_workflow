;; ============================================================
;; 种子工具库 - 纯 Lisp 实现的筛选/排序/格式化
;;
;; ```mermaid
;; graph TD
;;     A[原始结果列表] --> B[过滤低种]
;;     B -->|seeds >= 阈值| C[相关性过滤]
;;     C -->|标题含关键词| D[去重]
;;     D -->|hash 大写去重, O1 字典| E[来源优先排序]
;;     E -->|skrbtmv优先 + 做种数降序| F[取前N条]
;;     F --> G[格式化输出]
;;     G -->|带序号/大小/磁力链接| H[可读文本]
;; ```
;;
;; 依赖: 工具库/通用工具.lisp（去重通用、分组、任一满足?、索引映射）
;;
;; 导出函数:
;;   过滤低种          (结果列表, 最少做种) → 过滤后列表
;;   去重              (结果列表) → 去重后列表
;;   按做种排序        (结果列表) → 排序后列表
;;   按标题长度排序    (结果列表) → 排序后列表
;;   来源优先          (结果列表) → skrbtmv优先的排序列表
;;   标题相关?         (项目, 关键词) → 布尔值
;;   筛选种子管道      (结果列表, 最少做种) → top10列表
;;   筛选种子管道带关键词 (结果列表, 最少做种, 关键词) → top10列表
;;   格式化单条        (序号, 项目) → 格式化文本
;;   格式化结果        (结果列表) → 完整格式化文本
;;   摘要统计          (结果列表) → 统计摘要文本
;; ============================================================

【引入 "工具库/通用工具.lisp"】


;; ------------------------------------------------------------
;; 做种数辅助
;; 部分来源（skrbtmv/btsow）无法解析做种数，seeds 为 null
;; ------------------------------------------------------------

【定义 【做种已知? 项目】
  【非 【为空? 【取值 项目 "seeds"】】】】

【定义 【做种排序值 项目】
  【令 【【s 【取值 项目 "seeds"】】】
    【如果 【为空? s】 -1 s】】】


;; ------------------------------------------------------------
;; 过滤低种
;; 只保留做种数 >= 阈值的结果，低种子数的资源下载速度慢
;; 做种数未知的结果保留（无法判定为低种）
;; 参数: 结果列表 - 搜索结果; 最少做种 - 种子数阈值
;; 返回: 过滤后的列表
;; ------------------------------------------------------------

【定义 【过滤低种 结果列表 最少做种】
  【过滤
    【道 【r】
      【或 【非 【做种已知? r】】 【>= 【取值 r "seeds"】 最少做种】】】
    结果列表】】


;; ------------------------------------------------------------
;; 去重
;; 按 hash 字段去重（大写归一化），保留首次出现的条目
;; 利用通用库的 去重通用 函数，内部使用字典 O(1) 查找
;; 参数: 结果列表
;; 返回: 去重后的列表
;; ------------------------------------------------------------

【定义 【去重 结果列表】
  【去重通用 【道 【r】 【大写 【取值 r "hash"】】】 结果列表】】


;; ------------------------------------------------------------
;; 按做种排序
;; 按 seeds 字段降序排列，做种数越多下载越快
;; 参数: 结果列表
;; 返回: 排序后的列表
;; ------------------------------------------------------------

【定义 【按做种排序 结果列表】
  【排序
    【道 【a b】 【- 【做种排序值 b】 【做种排序值 a】】】
    结果列表】】


;; ------------------------------------------------------------
;; 来源优先
;; skrbtmv（中文种子站）结果排在前面，因为中文搜索更精准
;; skrbtmv 内部按标题长度升序（短标题 = 精确匹配）
;; 其他来源按做种数降序
;; 利用通用库的 分组 函数一次遍历分为两组
;; 参数: 结果列表
;; 返回: 重排序后的列表
;; ------------------------------------------------------------

【定义 【按标题长度排序 结果列表】
  【排序
    【道 【a b】 【- 【长度 【取值 a "title"】】 【长度 【取值 b "title"】】】】
    结果列表】】

【定义 【是中文源? 来源】
  【或 【= 来源 "skrbtmv"】
    【= 来源 "skrbtla"】
    【= 来源 "btsow"】】】

【定义 【来源优先 结果列表】
  【令 【【组 【分组 【道 【r】 【是中文源? 【取值 r "source"】】】 结果列表】】】
    【追加 【按标题长度排序 【取值 组 "是"】】 【按做种排序 【取值 组 "否"】】】】】


;; ------------------------------------------------------------
;; 标题相关性判断
;; 检查结果标题是否包含关键词中的任意一个词（按 | 分割）
;; 用于过滤搜索引擎返回的不相关噪声结果
;; 参数: 项目 - 单条结果; 关键词 - "词1|词2|..." 格式
;; 返回: #t 或 #f
;; ------------------------------------------------------------

【定义 【词有效? 词】
  【> 【长度 词】 1】】

;; 短语匹配：按空格拆词，任一有效词出现在标题中即视为相关
;; 解决 LLM 返回 "Breaking Bad (2008)" 无法匹配 "Breaking Bad S05E08" 的问题
【定义 【短语匹配标题? 标题 短语】
  【任一满足?
    【道 【词】 【与 【词有效? 词】 【文本包含 词 标题】】】
    【文本分割 " " 【小写 短语】】】】

【定义 【标题相关? 项目 关键词】
  【令 【【标题 【小写 【取值 项目 "title"】】】
        【词列表 【文本分割 "|" 关键词】】】
    【任一满足? 【道 【短语】 【短语匹配标题? 标题 短语】】 词列表】】】


;; ------------------------------------------------------------
;; 筛选种子管道
;; 组合筛选: 过滤低种 → 去重 → 来源优先 → 取前10
;; 参数: 结果列表, 最少做种
;; 返回: 精选 top 10 列表
;; ------------------------------------------------------------

【定义 【筛选种子管道 结果列表 最少做种】
  【取前 10
    【来源优先
      【去重
        【过滤低种 结果列表 最少做种】】】】】


;; ------------------------------------------------------------
;; 筛选种子管道（带关键词）
;; 增加标题相关性过滤步骤，去除与搜索词无关的噪声
;; 参数: 结果列表, 最少做种, 关键词
;; 返回: 精选 top 10 列表
;; ------------------------------------------------------------

【定义 【筛选种子管道带关键词 结果列表 最少做种 关键词】
  【取前 10
    【来源优先
      【去重
        【过滤
          【道 【r】 【标题相关? r 关键词】】
          【过滤低种 结果列表 最少做种】】】】】】


;; ------------------------------------------------------------
;; 格式化单条结果
;; 将单条搜索结果渲染为可读文本块
;; 格式:
;;   [序号] 标题 [来源]
;;       大小: xxx | 做种: xxx
;;       magnet:?xt=urn:btih:...
;; 参数: 序号 - 显示编号; 项目 - 结果字典
;; 返回: 格式化文本字符串
;; ------------------------------------------------------------

【定义 【格式化单条 序号 项目】
  【令 【【标题 【取值 项目 "title"】】
        【大小 【取值 项目 "size"】】
        【做种 【如果 【做种已知? 项目】 【转文本 【取值 项目 "seeds"】】 "未知"】】
        【来源 【取值 项目 "source"】】
        【磁力 【取值 项目 "magnet"】】】
    【文本拼接
      "[" 【转文本 序号】 "] " 标题 " [" 来源 "]\n"
      "    大小: " 大小
      【如果 【或 【= 来源 "skrbtmv"】 【非 【做种已知? 项目】】】 "" 【文本拼接 " | 做种: " 做种】】
      "\n"
      "    " 磁力 "\n"】】】


;; ------------------------------------------------------------
;; 格式化结果列表
;; 将筛选后的完整结果列表渲染为带编号的文本
;; 利用通用库的 索引映射 自动编号
;; 参数: 结果列表
;; 返回: 完整格式化文本，或空结果提示
;; ------------------------------------------------------------

【定义 【格式化结果 结果列表】
  【如果 【为空? 结果列表】
    "未找到相关种子资源。"
    【文本连接 "\n"
      【索引映射 【道 【序 项目】 【格式化单条 【+ 序 1】 项目】】 结果列表】】】】


;; ------------------------------------------------------------
;; 摘要统计
;; 输出结果数量和来源分布信息
;; 使用字典 key 做来源去重（O(1)）
;; 参数: 结果列表
;; 返回: "共 N 条结果，来源: xxx, yyy" 格式文本
;; ------------------------------------------------------------

【定义 【摘要统计 结果列表】
  【令 【【总数 【长度 结果列表】】
        【来源字典 【归约
          【道 【累加器 项目】
            【赋值 累加器 【取值 项目 "source"】 #t】】
          【字典】
          结果列表】】】
    【文本拼接
      "共 " 【转文本 总数】 " 条结果，来源: " 【文本连接 ", " 【键集 来源字典】】】】】


;; ------------------------------------------------------------
;; 输出种子卡片
;; 将结果列表通过 SSE 发送为结构化卡片（前端渲染为可交互组件）
;; 参数: 结果列表
;; 作用: 空列表打印提示，否则调用原语发送 JSON 到前端
;; ------------------------------------------------------------

【定义 【输出种子卡片 结果列表】
  【如果 【为空? 结果列表】
    【开始
      【打印 "未找到相关种子资源，请尝试其他关键词。"】
      【发送种子结果 结果列表】】
    【发送种子结果 结果列表】】】
