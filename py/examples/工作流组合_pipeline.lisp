;; ============================================================
;; 文章生成工作流 - pipeline 版【汉化版】
;;
;; 流程：
;;
;;   空上下文【字典】
;;       │
;;       ▼
;;   ┌──────────────┐
;;   │ 注入标题      │  赋值 "title" → ctx
;;   └─────┬────────┘
;;         │
;;         ▼
;;   ┌──────────────┐
;;   │ 生成大纲      │  调用模型 → 文本大纲
;;   └─────┬────────┘
;;         │
;;         ▼
;;   ┌──────────────┐
;;   │ 解析大纲      │  提取JSON → 列表
;;   └─────┬────────┘
;;         │
;;         ▼
;;   ┌──────────────┐
;;   │ 逐章扩写      │  映射: 每章调用模型
;;   └─────┬────────┘
;;         │
;;         ▼
;;   ┌──────────────┐
;;   │ 拼接文章      │  标题 + 各章正文
;;   └──────────────┘
;;
;; 特点：用 归约(reduce) 将节点列表串联为 pipeline
;; 依赖：调用模型, 提取JSON, 去除思考
;; ============================================================


;; ------------------------------------------------------------
;; 一、提示词模板【外部文件引用】
;; ------------------------------------------------------------

【定义 大纲提示词 "请为《{{标题}}》生成3个大纲章节"】
【定义 扩写提示词 【读文件 "prompts/章节扩写_简短.txt"】】


;; ------------------------------------------------------------
;; 二、Pipeline 节点
;;     每个节点：接收上下文(字典) → 返回更新后的上下文
;; ------------------------------------------------------------

;; 注入文章标题
【定义 【注入标题 上下文】
  【赋值 上下文 "title" "Lisp语言入门指南"】】

;; 调用模型生成大纲
【定义 【生成大纲 上下文】
  【令 【【提示词 【格式化 大纲提示词 "标题" 【取值 上下文 "title"】】】】
    【打印 ">>> 调用大模型生成大纲..."】
    【赋值 上下文 "outline" 【调用模型 提示词】】】】

;; 解析大纲为列表，失败则使用默认值
【定义 【解析大纲 上下文】
  【令 【【已解析 【提取JSON 【取值 上下文 "outline"】】】】
    【打印 ">>> 解析大纲..."】
    【赋值 上下文 "sections"
      【如果 【为空? 已解析】
          【序列 "第一章：Lisp简介" "第二章：函数定义" "第三章：宏"】
          已解析】】】】

;; 逐章调用模型扩写
【定义 【逐章扩写 上下文】
  【令 【【各章节 【取值 上下文 "sections"】】】
    【打印 ">>> 调用大模型扩写章节..."】
    【赋值 上下文 "articles"
      【映射 【道 【章节名】
               【令 【【正文 【去除思考 【调用模型 【格式化 扩写提示词 "章节" 章节名】】】】】
                 【文本拼接 "## " 章节名 "\n\n" 正文】】】
            各章节】】】】

;; 拼接为完整文章
【定义 【拼接文章 上下文】
  【令 【【标题 【取值 上下文 "title"】】】
    【令 【【文章列表 【取值 上下文 "articles"】】】
      【打印 ">>> 生成最终文章..."】
      【赋值 上下文 "final"
        【文本拼接 "# " 标题 "\n\n"
          【文本连接 "\n\n" 文章列表】】】】】】


;; ------------------------------------------------------------
;; 三、主工作流
;;     归约(reduce) 将节点列表串联为 pipeline
;; ------------------------------------------------------------

【定义 【执行工作流 上下文】
  【归约 【道 【当前上下文 当前节点】 【当前节点 当前上下文】】 上下文
    【序列 注入标题 生成大纲 解析大纲 逐章扩写 拼接文章】】】


;; ------------------------------------------------------------
;; 四、执行
;; ------------------------------------------------------------

【打印 ">>> 执行文章生成工作流【pipeline 汉化版】"】
【令 【【结果 【执行工作流 【字典】】】】
  【打印 ""】
  【打印 ">>> 生成的文章："】
  【打印 【取值 结果 "final"】】】
