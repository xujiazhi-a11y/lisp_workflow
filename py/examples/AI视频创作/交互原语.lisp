;; ============================================================
;; 交互原语：选帧、优化描述、生成视频 的交互式循环
;; ============================================================

【定义 【交互选帧 片段描述 段号】
  【打印 ">>> 生成首尾帧候选图..."】
  【定义 帧候选 【生成帧候选 片段描述】】
  【定义 候选首帧 【取项 0 帧候选】】
  【定义 候选尾帧 【取项 1 帧候选】】
  【打印 "  首帧: " 候选首帧】
  【打印 "  尾帧: " 候选尾帧】
  【打印 ""】

  【定义 选项集
    【序列
      【字典 "label" "使用这组帧" "value" "1" "image" 候选首帧 "image2" 候选尾帧】
      【字典 "label" "重新生成一组" "value" "2"】】】

  【定义 提示文本 【文本拼接 "请选择「片段 " 【转文本 段号】 "」的首尾帧组合"】】
  【定义 选帧结果 【选择 提示文本 选项集】】

  【如果 【= 选帧结果 "1"】
    【序列 候选首帧 候选尾帧】
    【交互选帧 片段描述 段号】】】

【定义 【交互优化描述 片段描述】
  【定义 当前描述 【生成视频描述 片段描述】】
  【交互优化描述循环 当前描述 片段描述】】

【定义 【交互优化描述循环 当前描述 片段描述】
  【打印 ""】
  【打印 ">>> 视频描述提示词: " 当前描述】

  【定义 选项集
    【序列
      【字典 "label" "使用这个提示词" "value" "1"】
      【字典 "label" "重新生成" "value" "2"】】】

  【定义 描述选择 【选择 "请确认视频描述提示词（也可自由输入修改意见）" 选项集】】

  【如果 【= 描述选择 "1"】
    当前描述
    【开始
      【定义 修改意见 【用户输入 "请输入修改意见："】】
      【定义 新描述 【优化视频描述 当前描述 修改意见】】
      【打印 "  已重新生成提示词"】
      【交互优化描述循环 新描述 片段描述】】】】

【定义 【交互生成视频 首帧 尾帧 描述 时长 段号】
  【交互生成视频循环 首帧 尾帧 描述 时长 段号 【序列】】】

【定义 【交互生成视频循环 首帧 尾帧 描述 时长 段号 历史列表】
  【打印 ""】
  【打印 ">>> 生成视频... 提示词: " 【文本裁剪 描述】】
  【定义 视频路径 【生成视频 首帧 尾帧 描述 时长】】
  【定义 新历史 【追加 历史列表 视频路径】】
  【打印 "  ✓ 视频已生成: " 视频路径】

  【定义 选项3
    【如果 【> 【长度 新历史】 1】
      【字典 "label" "选历史版本 1" "value" "h0" "video" 【取项 0 新历史】】
      【序列】】】

  【定义 选项集
    【如果 【> 【长度 新历史】 1】
      【序列
        【字典 "label" "使用当前版本" "value" "1" "video" 视频路径】
        【字典 "label" "重新生成一个新版本" "value" "2"】
        选项3】
      【序列
        【字典 "label" "使用当前版本" "value" "1" "video" 视频路径】
        【字典 "label" "重新生成一个新版本" "value" "2"】】】】

  【定义 提示文本 【文本拼接 "请选择「片段 " 【转文本 段号】 "」的视频版本"】】
  【定义 选 【选择 提示文本 选项集】】

  【如果 【= 选 "1"】
    【开始 【打印 "  ✓ 已选定当前版本"】 视频路径】
    【如果 【= 选 "2"】
      【开始 【打印 "  重新生成中..."】
        【交互生成视频循环 首帧 尾帧 描述 时长 段号 新历史】】
      【取项 0 新历史】】】】
