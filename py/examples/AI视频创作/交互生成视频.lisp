;; ============================================================
;; 四、交互式视频生成（递归实现循环，保留历史版本）
;; ============================================================

【定义 【交互生成视频 首帧 尾帧 描述 时长 段号】
  【交互生成视频循环 首帧 尾帧 描述 时长 段号 【序列】】】

【定义 【交互生成视频循环 首帧 尾帧 描述 时长 段号 历史列表】
  【打印 ""】
  【打印 ">>> 生成视频... 提示词: " 【文本裁剪 描述】】
  【定义 视频路径 【生成视频 首帧 尾帧 描述 时长】】
  【定义 新历史 【追加 历史列表 视频路径】】
  【打印 "  ✓ 视频已生成: " 视频路径】

  ;; 选项1: 使用当前版本（带视频预览）
  【定义 选项1
    【字典
      "label" "使用当前版本"
      "value" "1"
      "video" 视频路径】】
  ;; 选项2: 重新生成
  【定义 选项2
    【字典
      "label" "重新生成一个新版本"
      "value" "2"】】
  ;; 选项3: 选历史版本（如果有）
  【定义 选项3
    【如果 【> 【长度 新历史】 1】
      【字典
        "label" "选历史版本 1"
        "value" "h0"
        "video" 【取项 0 新历史】】
      【序列】】】

  【定义 选项集
    【如果 【> 【长度 新历史】 1】
      【序列 选项1 选项2 选项3】
      【序列 选项1 选项2】】】

  【定义 提示文本
    【文本拼接 "请选择「片段 " 【转文本 段号】 "」的视频版本"】】
  【定义 选 【选择 提示文本 选项集】】

  【如果 【= 选 "1"】
    【开始
      【打印 "  ✓ 已选定当前版本"】
      视频路径】
    【如果 【= 选 "2"】
      【开始
        【打印 "  重新生成中..."】
        【交互生成视频循环 首帧 尾帧 描述 时长 段号 新历史】】
      【取项 0 新历史】】】】
