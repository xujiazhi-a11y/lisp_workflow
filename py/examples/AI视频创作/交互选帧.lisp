;; ============================================================
;; 二、交互式选帧（递归实现循环）
;; ============================================================

【定义 【交互选帧 片段描述 段号】
  【打印 ">>> 生成首尾帧候选图..."】
  【定义 帧候选 【生成帧候选 片段描述】】
  【定义 候选首帧 【取项 0 帧候选】】
  【定义 候选尾帧 【取项 1 帧候选】】
  【打印 "  首帧: " 候选首帧】
  【打印 "  尾帧: " 候选尾帧】
  【打印 ""】

  【定义 选项1
    【字典
      "label" "使用这组帧"
      "value" "1"
      "image" 候选首帧
      "image2" 候选尾帧】】
  【定义 选项2
    【字典
      "label" "重新生成一组"
      "value" "2"】】
  【定义 选项集 【序列 选项1 选项2】】

  【定义 提示文本
    【文本拼接 "请选择「片段 " 【转文本 段号】 "」的首尾帧组合"】】
  【定义 选帧结果 【选择 提示文本 选项集】】

  【如果 【= 选帧结果 "1"】
    【序列 候选首帧 候选尾帧】
    【交互选帧 片段描述 段号】】】
